# pyenv
#   For a library or app, you might want to share your .python-version if you
#   use pyenv.
#  .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if used, it can be useful to ignore it.
#   Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock is database file and can be ignored.
#   poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock is database file and can be ignored.
#   pdm.lock

# PEP 582; used by e.g. github.com/pdm-project/pdm
__pypackages__/

